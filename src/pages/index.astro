---
import Base from "../layouts/Base.astro";
---

<Base>
  <section class="page-shell">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <h1 class="hero-title">
            <span
              class="hero-highlight"
              tabindex="0"
              aria-label="Huy, pronounced hwee"
            >
              Huy
              <span class="hero-pronunciation-popover">/hwee/</span>
            </span>{" "}
            X. Dang
          </h1>
          <p class="hero-text">Applied AI researcher &amp; software engineer.</p>

          <p class="hero-text">
            I studied Statistics &amp; Math at the{" "}
            <a
              href="https://www.utoronto.ca/"
              target="_blank"
              rel="noopener noreferrer"
              class="accent-link">University of Toronto</a
            >
            and did research at the New Turing Institute under{" "}
            <a
              href="https://research.google/people/105176/?&type=google"
              target="_blank"
              rel="noopener noreferrer"
              class="accent-link">Dr. Thang Luong</a
            >. I created{" "}
            <a
              href="https://huyxdang.github.io/Emoji-Bench-Page/"
              target="_blank"
              rel="noopener noreferrer"
              class="accent-link">Emoji-Bench</a
            >
            to measure self-correction ability in LLMs, which was presented at
            the{" "}
            <a
              href="https://summit.newturing.ai/"
              target="_blank"
              rel="noopener noreferrer"
              class="accent-link">GStar AI Summit</a
            >.
          </p>
          <p class="hero-text">
            I also enjoy building. I've built{" "}
            <a
              href="https://neurips-2025.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="accent-link">NeurIPS Map</a
            >
            to explore research papers; and{" "}
            <a
              href="https://www.youtube.com/watch?v=dKt-yfZ82qw&t=63s"
              target="_blank"
              rel="noopener noreferrer"
              class="accent-link">NaviBuddy</a
            >, AI for the visually-disabled, which received $15k+ and was
            nominated for the Paris SDG Olympiad.
          </p>

          <p class="interests">
            I'm Vietnamese: I enjoy exploring the world on my motorbike!
          </p>
        </div>

        <div class="social-links" aria-label="Social links">
          <a
            href="https://www.linkedin.com/in/huy-x-dang/"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
            aria-label="LinkedIn"
            title="LinkedIn"
          >
            <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
          </a>
          <a
            href="https://github.com/huyxdang"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
            aria-label="GitHub"
            title="GitHub"
          >
            <i class="fa-brands fa-github" aria-hidden="true"></i>
          </a>
          <a
            href="https://x.com/xhuydang"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
            aria-label="X"
            title="X"
          >
            <i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
          </a>
        </div>

        <div class="hero-photo">
          <a
            href="https://www.linkedin.com/in/huy-x-dang/"
            target="_blank"
            rel="noopener noreferrer"
            class="hero-photo-link"
            aria-label="Open Huy X. Dang on LinkedIn"
          >
            <img src="/headshot.jpg" alt="Huy Dang" />
          </a>
        </div>
        <p class="hero-photo-caption">Ta Xua, Viet Nam</p>
      </div>
    </div>
  </section>
</Base>
